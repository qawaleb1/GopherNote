@inject SpeechService SpeechService
@inject IJSRuntime JS
@inject NoteService NoteService
@implements IDisposable

<div class="editor-container">
    <div class="editor-header">
        <input class="title-input" @bind="Note.Title" placeholder="Заголовок заметки..." />
    </div>

    @* Верхняя панель: инструменты *@
    <div class="editor-toolbar">
        <div class="toolbar-main-row">
            <div class="template-picker-group">
                <button type="button" class="main-button template-button" @onclick="ToggleTemplateMenu">
                    🎨 Шаблоны: <strong>@GetTemplateName()</strong>
                </button>

                @if (showTemplateMenu)
                {
                    <div class="template-dropdown">
                        <div class="template-option @(GetCurrentTemplate() == 1 ? "selected" : "")" @onclick="() => SelectTemplate(1)">
                            <div class="template-preview template-1"></div>
                            <span class="template-name">Классический</span>
                        </div>

                        <div class="template-option @(GetCurrentTemplate() == 2 ? "selected" : "")" @onclick="() => SelectTemplate(2)">
                            <div class="template-preview template-2"></div>
                            <span class="template-name">Минимализм</span>
                        </div>

                        <div class="template-option @(GetCurrentTemplate() == 3 ? "selected" : "")" @onclick="() => SelectTemplate(3)">
                            <div class="template-preview template-3"></div>
                            <span class="template-name">Акцент</span>
                        </div>

                        <div class="template-option @(GetCurrentTemplate() == 4 ? "selected" : "")" @onclick="() => SelectTemplate(4)">
                            <div class="template-preview template-4"></div>
                            <span class="template-name">Элегантный</span>
                        </div>
                    </div>
                }
            </div>

            <button type="button" class="@(isRecording ? "btn-danger" : "main-button")" @onclick="ToggleRecording" disabled="@isSaving">
                @(isRecording ? "⏹ Остановить запись" : "🎙 Голосовой ввод")
            </button>

            <button type="button" class="main-button" @onclick="OpenTagDialog" disabled="@isSaving">Добавить тег</button>

            <button type="button" class="pin-icon" style="margin-left: auto" @onclick="TogglePin">@(Note.IsPinned ? "★ Закреплено" : "☆ Закрепить")</button>

            <dialog id="tagDialog" class="tag-dialog">
                <h3 style="text-align: center">Добавить тег</h3>


                <div style="text-align: center; margin-bottom: 10px; font-size: 0.8rem; color: var(--text-muted);">
                    Тегов: @Note.Tags.Count / @MaxTags
                </div>

                <input type="text"
                       placeholder="Название тега..."
                       class="dialog-input"
                       @bind="newTag"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown" />

                @* Отображение ошибки *@
                @if (!string.IsNullOrEmpty(tagErrorMessage))
                {
                    <div style="color: #ef4444; font-size: 0.75rem; margin-top: 8px; text-align: center;">
                        @tagErrorMessage
                    </div>
                }

                <div class="dialog-buttons">
                    <button type="button" class="main-button" style="width: 50%;" @onclick="AddTagFromDialog" disabled="@(Note.Tags.Count >= MaxTags)">
                        Добавить
                    </button>
                    <button type="button" class="btn-outline" style="width: 50%;" @onclick="CloseDialog">
                        Отмена
                    </button>
                </div>
            </dialog>
        </div>
    </div>

    @* Блок отображения тегов *@
    <div class="tags" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 0.5rem;">
        @if (Note.Tags != null && Note.Tags.Any())
        {
            @foreach(var tag in Note.Tags)
            {
                <span class="tag" style="background: var(--bg-input); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; border: 1px solid var(--border-light); color: var(--text-primary);">
                    #@tag
                    <span class="remove-tag" style="color: var(--error); cursor: pointer; margin-left: 5px; font-weight: bold;" @onclick="() => RemoveTag(tag)">×</span>
                </span>
            }

            @* Сообщение о достижении лимита *@
            @if (Note.Tags.Count >= MaxTags)
            {
                <span style="font-size: 0.7rem; color: #ef4444; margin-left: 8px;">
                    ⚠️ Лимит @MaxTags тегов
                </span>
            }
        }
        else
        {
            <span style="font-size: 0.8rem; color: var(--text-muted);">Нет тегов</span>
        }
    </div>

    @* Панель форматирования *@
    <div class="markdown-toolbar" style="margin-bottom: 0.75rem; justify-content: flex-start;">
        <button type="button" class="btn-outline btn-md-format" style="font-weight: bold;" @onclick='() => WrapSelection("**", "**")' title="Жирный">B</button>
        <button type="button" class="btn-outline btn-md-format" style="font-style: italic;" @onclick='() => WrapSelection("*", "*")' title="Курсив">I</button>
        <button type="button" class="btn-outline btn-md-format" style="text-decoration: line-through;" @onclick='() => WrapSelection("~~", "~~")' title="Зачеркнутый">S</button>
        <button type="button" class="btn-outline btn-md-format" style="font-family: monospace;" @onclick='() => WrapSelection("`", "`")' title="Код">&lt;/&gt;</button>

        <span class="toolbar-divider">|</span>

        <button type="button" class="btn-outline btn-md-format" @onclick='() => WrapSelection("# ", "")' title="Заголовок H1">H1</button>
        <button type="button" class="btn-outline btn-md-format" @onclick='() => WrapSelection("## ", "")' title="Заголовок H2">H2</button>
    </div>

    <div class="editor-body">
        <div class="textarea-wrapper">
            <textarea id="md-editor-textarea" class="md-editor" @bind="Note.Content" @bind:event="oninput" placeholder="Пишите здесь..."></textarea>

            @if (isRecording)
            {
                <div class="voice-interim">
                    <i>@interimText</i>
                </div>
            }
        </div>

        <div class="md-preview @Note.TemplateClass">
            <MarkdownView Content="@Note.Content"/>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-toast" style="background-color: var(--error, #ef4444); color: white; padding: 12px 16px; border-radius: 8px; font-size: 0.95rem; font-weight: 500; margin-bottom: 1rem; width: 100%; box-sizing: border-box;">
            @errorMessage
        </div>
    }

    <div class="editor-actions">
        <button type="button" class="main-button" @onclick="HandleSave" disabled="@isSaving">
            @(isSaving ? "Сохранение..." : "Сохранить")
        </button>
        <button type="button" class="btn-outline" @onclick="ShowCancelWarning" disabled="@isSaving">Отмена</button>

        @if (!IsNewNote)
        {
            <button type="button" class="btn-danger" @onclick="ShowDeleteWarning" disabled="@isSaving">Удалить</button>
        }
    </div>

    @if (showEmptyWarningModal)
    {
        <div class="custom-modal-overlay">
            <div class="custom-modal-card">
                <div class="custom-modal-header">
                    <span class="warning-icon">⚠️</span>
                    <h4>Пустая заметка</h4>
                </div>
                <div class="custom-modal-body">
                    <p>Вы точно хотите создать пустую заметку?</p>
                </div>
                <div class="custom-modal-actions">
                    <button type="button" class="main-button" @onclick="ConfirmSaveEmpty">Да, создать</button>
                    <button type="button" class="btn-outline" @onclick="CancelSaveEmpty">Нет</button>
                </div>
            </div>
        </div>
    }
    @* Модальное окно подтверждения удаления *@
    @if (showDeleteWarningModal)
    {
        <div class="custom-modal-overlay">
            <div class="custom-modal-card">
                <div class="custom-modal-header">
                    <span class="warning-icon">⚠️</span>
                    <h4>Удаление заметки</h4>
                </div>
                <div class="custom-modal-body">
                    <p>Вы уверены, что хотите удалить заметку "<strong>@Note.Title</strong>"?</p>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 8px;">Это действие нельзя отменить.</p>
                </div>
                <div class="custom-modal-actions">
                    <button type="button" class="btn-danger" style="width: 50%;"@onclick="ConfirmDelete">Да, удалить</button>
                    <button type="button" class="btn-outline" style="width: 50%;"@onclick="CancelDeleteWarning">Отмена</button>
                </div>
            </div>
        </div>
    }

    @* Модальное окно подтверждения отмены *@
    @if (showCancelWarningModal)
    {
        <div class="custom-modal-overlay">
            <div class="custom-modal-card">
                <div class="custom-modal-header">
                    <span class="warning-icon">⚠️</span>
                    <h4>Отмена редактирования</h4>
                </div>
                <div class="custom-modal-body">
                    <p>Все несохранённые изменения будут потеряны.</p>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 8px;">Вы уверены, что хотите выйти без сохранения?</p>
                </div>
                <div class="btn-modals-group">
                    <div class="custom-modal-actions">
                        <button type="button" class="btn-outline" @onclick="CancelCancelWarning">Продолжить редактирование</button>
                    </div>
                    <div class="custom-modal-actions">
                        <button type="button" class="btn-danger" style="width: 100%;"@onclick="ConfirmCancel">Выйти</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private const int MaxTags = 11;

    [Parameter] public Note Note { get; set; } = new();
    [Parameter] public EventCallback<Note> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsNewNote { get; set; } = false;
    [Parameter] public EventCallback<Note> OnDelete { get; set; }

    private bool isRecording = false;
    private string interimText = "Говорите...";
    private string newTag = "";
    private bool showEmptyWarningModal = false;

    private string? errorMessage = null;
    private bool isSaving = false;

    // Переменные для шаблонов
    private bool showTemplateMenu = false;

    private bool showDeleteWarningModal = false;
    private bool showCancelWarningModal = false;

    private string tagErrorMessage = "";

    private void HandleTagKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTag();
    }

    protected override void OnInitialized()
    {
        if (Note.Tags == null) Note.Tags = new List<string>();

        // Устанавливаем шаблон по умолчанию, если его нет
        if (string.IsNullOrEmpty(Note.TemplateClass))
        {
            Note.TemplateClass = "note-template-2";  // Меняем с 1 на 2
        }

        Console.WriteLine($"=== OnInitialized: TemplateClass = {Note.TemplateClass}, Title = {Note.Title} ===");

        SpeechService.OnRecognized += HandleSpeechRecognized;
        SpeechService.OnEnded += HandleSpeechEnded;
    }

    protected override void OnParametersSet()
    {
        // Дополнительная проверка при каждом обновлении параметров
        if (string.IsNullOrEmpty(Note.TemplateClass))
        {
            Note.TemplateClass = "note-template-1";
        }
        Console.WriteLine($"=== OnParametersSet: TemplateClass = {Note.TemplateClass} ===");
    }

    private void AddTag()
    {
        tagErrorMessage = "";

        if (!string.IsNullOrWhiteSpace(newTag))
        {
            var cleanedTag = newTag.Trim().Replace("#", "");

            // Проверка на максимальное количество тегов
            if (Note.Tags.Count >= MaxTags)
            {
                tagErrorMessage = $"⚠️ Достигнуто максимальное количество тегов ({MaxTags})";
                return;
            }

            if (!Note.Tags.Contains(cleanedTag, StringComparer.OrdinalIgnoreCase))
            {
                Note.Tags.Add(cleanedTag);
            }
            newTag = "";
        }
    }

    private void RemoveTag(string tag)
    {
        Note.Tags.Remove(tag);
        tagErrorMessage = ""; // Очищаем ошибку при удалении
        StateHasChanged();
    }

    private async Task ToggleRecording()
    {
        if (isRecording)
        {
            await SpeechService.StopRecognitionAsync();
            isRecording = false;
        }
        else
        {
            bool started = await SpeechService.StartRecognitionAsync("ru-RU");
            if (started) isRecording = true;
        }
    }

    private void HandleSpeechRecognized(string final, string interim)
    {
        interimText = string.IsNullOrWhiteSpace(interim) ? "Говорите..." : interim;
        if (!string.IsNullOrWhiteSpace(final))
        {
            Note.Content += (string.IsNullOrWhiteSpace(Note.Content) ? "" : " ") + final;
        }
        StateHasChanged();
    }

    private void HandleSpeechEnded()
    {
        isRecording = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        SpeechService.OnRecognized -= HandleSpeechRecognized;
        SpeechService.OnEnded -= HandleSpeechEnded;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("setupMarkdownTextarea", "md-editor-textarea");
        }
    }

    private void TogglePin() => Note.IsPinned = !Note.IsPinned;

    private async Task WrapSelection(string prefix, string suffix)
    {
        try
        {
            var selection = await JS.InvokeAsync<TextareaSelection>("getTextareaSelection", "md-editor-textarea");

            var content = Note.Content ?? "";
            var start = selection.Start;
            var end = selection.End;

            var selectedText = content.Substring(start, end - start);
            var newText = content.Substring(0, start) + prefix + selectedText + suffix + content.Substring(end);

            Note.Content = newText;
            StateHasChanged();

            await JS.InvokeVoidAsync("setTextareaSelection", "md-editor-textarea", start + prefix.Length, end + prefix.Length);
        }
        catch
        {
            Note.Content += prefix + suffix;
        }
    }

    private class TextareaSelection
    {
        public int Start { get; set; }
        public int End { get; set; }
    }

    private void AddTagFromDialog()
    {
        tagErrorMessage = ""; // Очищаем сообщение об ошибке

        if (!string.IsNullOrWhiteSpace(newTag))
        {
            var cleanedTag = newTag.Trim().Replace("#", "");

            // Проверка на максимальное количество тегов
            if (Note.Tags.Count >= MaxTags)
            {
                tagErrorMessage = $"⚠️ Достигнуто максимальное количество тегов ({MaxTags}). Удалите лишние теги перед добавлением новых.";
                return;
            }

            // Проверка на дубликаты
            if (!Note.Tags.Contains(cleanedTag, StringComparer.OrdinalIgnoreCase))
            {
                Note.Tags.Add(cleanedTag);
                newTag = "";
            }
            else
            {
                tagErrorMessage = "⚠️ Такой тег уже существует";
            }
        }
        CloseDialog();
    }

    private async Task OpenTagDialog()
    {
        newTag = ""; // Очищаем поле при открытии
        tagErrorMessage = ""; // Очищаем сообщение об ошибке
        await JS.InvokeVoidAsync("eval", "document.getElementById('tagDialog').showModal()");
    }

    private void CloseDialog()
    {
        newTag = "";
        JS.InvokeVoidAsync("eval", "document.getElementById('tagDialog').close()");
    }
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTagFromDialog();
        }
    }


    private async Task HandleSave()
    {
        bool isTitleEmpty = string.IsNullOrWhiteSpace(Note.Title);
        bool isContentEmpty = string.IsNullOrWhiteSpace(Note.Content);

        if (isTitleEmpty && isContentEmpty)
        {
            showEmptyWarningModal = true;
            return;
        }

        await ExecuteSaveAsync();
    }

    private async Task ConfirmSaveEmpty()
    {
        showEmptyWarningModal = false;
        await ExecuteSaveAsync();
    }

    private async Task ExecuteSaveAsync()
    {
        errorMessage = null;
        isSaving = true;
        try
        {
            Console.WriteLine($"=== ПЕРЕД СОХРАНЕНИЕМ: TemplateClass = {Note.TemplateClass} ===");
            await OnSave.InvokeAsync(Note);
            Console.WriteLine($"=== ПОСЛЕ СОХРАНЕНИЯ: TemplateClass = {Note.TemplateClass} ===");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения: {ex.Message}");
            errorMessage = "⚠️ Не удалось сохранить заметку. Попробуйте позже.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ExecuteDeleteAsync()
    {
        errorMessage = null;
        isSaving = true;
        try
        {
            await OnDelete.InvokeAsync(Note);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка удаления: {ex.Message}");
            errorMessage = "⚠️ Не удалось удалить заметку. Попробуйте позже.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelSaveEmpty()
    {
        showEmptyWarningModal = false;
    }

    private string ResolveTextColor()
    {
        if (string.IsNullOrEmpty(Note.TextColor) || Note.TextColor == "#00000000")
        {
            if (string.IsNullOrWhiteSpace(Note.Color) || !Note.Color.StartsWith("#"))
                return "var(--text-primary)";

            try
            {
                string hex = Note.Color.Trim().Replace("#", "");
                int r = Convert.ToInt32(hex.Substring(0, 2), 16);
                int g = Convert.ToInt32(hex.Substring(2, 2), 16);
                int b = Convert.ToInt32(hex.Substring(4, 2), 16);

                int yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
                return yiq >= 128 ? "#000000" : "#FFFFFF";
            }
            catch
            {
                return "var(--text-primary)";
            }
        }

        return Note.TextColor;
    }

    // Методы для работы с шаблонами
    private void ToggleTemplateMenu()
    {
        showTemplateMenu = !showTemplateMenu;
    }

    private int GetCurrentTemplate()
    {
        if (string.IsNullOrEmpty(Note.TemplateClass))
            return 2;  // Меняем с 1 на 2 (Минимализм)

        switch (Note.TemplateClass)
        {
            case "note-template-1": return 1;
            case "note-template-2": return 2;
            case "note-template-3": return 3;
            case "note-template-4": return 4;
            default: return 2;  // Меняем с 1 на 2
        }
    }
    private string GetTemplateName()
    {
        switch (GetCurrentTemplate())
        {
            case 1: return "Классический";
            case 2: return "Минимализм";
            case 3: return "Акцент";
            case 4: return "Элегантный";
            default: return "Минимализм";  // Меняем с "Классический"
        }
    }

    private void SelectTemplate(int templateId)
    {
        string newTemplate = templateId switch
        {
            1 => "note-template-1",
            2 => "note-template-2",
            3 => "note-template-3",
            4 => "note-template-4",
            _ => "note-template-1"
        };

        Note.TemplateClass = newTemplate;
        showTemplateMenu = false;
        StateHasChanged();

        Console.WriteLine($"=== ВЫБРАН ШАБЛОН: {templateId} -> {Note.TemplateClass} ===");
    }
     // Предупреждение об удалении
     private void ShowDeleteWarning()
     {
         showDeleteWarningModal = true;
         StateHasChanged();
     }

     private void CancelDeleteWarning()
     {
         showDeleteWarningModal = false;
         StateHasChanged();
     }

     private async Task ConfirmDelete()
     {
         showDeleteWarningModal = false;
         await ExecuteDeleteAsync();
     }

// Предупреждение об отмене
     private void ShowCancelWarning()
     {
         showCancelWarningModal = true;
         StateHasChanged();
     }

     private void CancelCancelWarning()
     {
         showCancelWarningModal = false;
         StateHasChanged();
     }

     private async Task ConfirmCancel()
     {
         showCancelWarningModal = false;
         await OnCancel.InvokeAsync();
     }
}
