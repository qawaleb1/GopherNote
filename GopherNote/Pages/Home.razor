@page "/"
@using GopherNote.Models
@using GopherNote.Services
@using Microsoft.JSInterop
@inject NoteService NoteService
@inject QuoteService QuoteService
@inject IJSRuntime JS

<PageTitle>GopherNote</PageTitle>

<div class="layout">
    <!-- Цитата на всю ширину вверху -->
    <TopQuote Quote="@CurrentQuote" />

    <!-- Контейнер для сайдбара и основного контента -->
    <div class="main-content">
        <aside class="sidebar">
            <button class="main-button" @onclick="CreateNewNote">Новая заметка</button>

            <div class="filters">
                <h3 style="text-align: center">Фильтры</h3>
                <input type="text" placeholder="Поиск по тегам..." @bind="tagFilter" @bind:event="oninput"/>
                <input type="text" placeholder="Поиск по названию..." @bind="Title" @bind:event="oninput"/>
            </div>
            <div class="filters">
                <h3 style="text-align: center">Сортировка</h3>
                <!-- Кастомный select -->
                <div class="custom-select-wrapper">
                    <div class="custom-select" @onclick="ToggleSelect">
                        @(sortBy == "date_desc" ? "Сначала новые" : "Сначала старые")
                    </div>
                    <div class="custom-select-list @(showSelect ? "show" : "")">
                        <div class="custom-select-option @(sortBy == "date_desc" ? "selected" : "")" @onclick="SelectDateDesc">
                            Сначала новые
                        </div>
                        <div class="custom-select-option @(sortBy == "date_asc" ? "selected" : "")" @onclick="SelectDateAsc">
                            Сначала старые
                        </div>
                    </div>
                </div>
            </div>
            <div class="github-team">
                <div class="github-header">
                    <span>👥 Участники проекта</span>
                </div>

                <div class="github-list">
                    <a href="https://github.com/0xddi" target="_blank" rel="noopener noreferrer" class="github-link">
                        <span class="role-icon techlead">🧠</span>
                        <span>0xddi</span>
                        <span class="role-badge techlead">ТехЛид</span>
                        <span class="github-icon">→</span>
                    </a>

                    <a href="https://github.com/legolordr" target="_blank" rel="noopener noreferrer" class="github-link">
                        <span class="role-icon dev">💻</span>
                        <span>legolordr</span>
                        <span class="role-badge dev">Разработчик</span>
                        <span class="github-icon">→</span>
                    </a>

                    <a href="https://github.com/qawaleb1" target="_blank" rel="noopener noreferrer" class="github-link">
                        <span class="role-icon dev">💻</span>
                        <span>qawaleb1</span>
                        <span class="role-badge dev">Разработчик</span>
                        <span class="github-icon">→</span>
                    </a>

                    <a href="https://github.com/friendkvz" target="_blank" rel="noopener noreferrer" class="github-link">
                        <span class="role-icon dev">💻</span>
                        <span>friendkvz</span>
                        <span class="role-badge dev">Разработчик</span>
                        <span class="github-icon">→</span>
                    </a>

                    <a href="https://github.com/Vo1dS02" target="_blank" rel="noopener noreferrer" class="github-link">
                        <span class="role-icon qa">🔍</span>
                        <span>Vo1dS02</span>
                        <span class="role-badge qa">QA инженер</span>
                        <span class="github-icon">→</span>
                    </a>
                </div>
            </div>
        </aside>

        <main class="content">
            @if (isEditing)
            {
                <EditNote Note="currentEditingNote"
                          IsNewNote="@(!allNotes.Any(n => n.Id == currentEditingNote.Id))"
                          OnSave="SaveNote"
                          OnCancel="CancelEdit"
                          OnDelete="DeleteNote" />
            }
            else
            {
                <div class="notes-grid">
                    @foreach (var note in FilteredAndSortedNotes)
                    {
                        <NoteCard Note="note" OnPinToggled="SaveNote" OnEdit="StartEdit"/>
                    }
                </div>
            }
        </main>
    </div>
</div>

<style>
    /* ========== СТИЛИ ДЛЯ КАСТОМНОГО SELECT ========== */
    .custom-select-wrapper {
        position: relative;
        width: 100%;
    }

    .custom-select {
        width: 100%;
        padding: 8px 32px 8px 12px;
        background-color: var(--bg-input);
        color: var(--text-primary);
        border: 1px solid var(--border-medium);
        border-radius: 8px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.85rem;
        font-weight: 400;
        cursor: pointer;
        transition: all 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236366f1' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 12px center;
        background-size: 16px;
    }

    .custom-select:hover {
        background-color: var(--bg-hover);
        border-color: var(--accent);
    }

    .custom-select-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        margin-top: 4px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-medium);
        border-radius: 8px;
        box-shadow: var(--shadow-dropdown);
        z-index: 1000;
        display: none;
        overflow: hidden;
    }

    .custom-select-list.show {
        display: block;
    }

    .custom-select-option {
        padding: 10px 12px;
        cursor: pointer;
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.85rem;
        transition: all 0.2s;
    }

    .custom-select-option:hover {
        background-color: var(--accent-light);
        color: var(--accent);
    }

    .custom-select-option.selected {
        background-color: var(--accent);
        color: white;
    }

    /* Тёмная тема для селекта */
    .dark-theme .custom-select {
        background-color: var(--bg-input);
    }

    .dark-theme .custom-select-list {
        background-color: var(--bg-card);
        border-color: var(--border-medium);
    }
    ::-webkit-scrollbar {
        width: 0px !important;
        height: 0px !important;
        background: transparent !important;
        display: none !important;
    }

    * {
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
    }

    body, html {
        overflow-y: scroll !important;
    }
</style>

@code {
    private List<Note> allNotes = new();
    private string CurrentQuote = "";
    private string tagFilter = "";
    private string Title = "";
    private string sortBy = "date_desc";

    private bool isEditing = false;
    private Note currentEditingNote = new();

    private bool showSelect = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadData();
                StateHasChanged();

                // Инициализация для закрытия селекта при клике вне
                await JS.InvokeVoidAsync("setupClickOutside", DotNetObjectReference.Create(this));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка загрузки: {ex.Message}");
            }
        }
    }

    private async Task LoadData()
    {
        allNotes = await NoteService.GetNotesAsync();
        CurrentQuote = QuoteService.GetContextualQuote(allNotes);
        StateHasChanged();
    }

    private IEnumerable<Note> FilteredAndSortedNotes
    {
        get
        {
            var filtered = allNotes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(tagFilter))
            {
                filtered = filtered.Where(n => n.Tags != null &&
                                               n.Tags.Any(t => t.Contains(tagFilter, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(Title))
            {
                filtered = filtered.Where(n => n.Title != null && n.Title.Contains(Title, StringComparison.OrdinalIgnoreCase));
            }

            if (sortBy == "date_desc")
            {
                return filtered.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt);
            }
            else
            {
                return filtered.OrderByDescending(n => n.IsPinned).ThenBy(n => n.CreatedAt);
            }
        }
    }

    private void CreateNewNote()
    {
        currentEditingNote = new Note
        {
            TemplateClass = "note-template-2"
        };
        isEditing = true;
    }

    private void StartEdit(Note note)
    {
        currentEditingNote = new Note
        {
            Id = note.Id,
            Title = note.Title,
            Content = note.Content,
            IsPinned = note.IsPinned,
            Color = note.Color,
            TextColor = note.TextColor,
            Tags = note.Tags != null ? new List<string>(note.Tags) : new List<string>(),
            CreatedAt = note.CreatedAt,
            UpdatedAt = note.UpdatedAt,
            TemplateClass = note.TemplateClass
        };
        isEditing = true;
    }

    private async Task SaveNote(Note note)
    {
        await NoteService.SaveNoteAsync(note);

        var index = allNotes.FindIndex(n => n.Id == note.Id);
        if (index != -1)
        {
            allNotes[index] = note;
        }
        else
        {
            allNotes.Add(note);
        }

        isEditing = false;
        CurrentQuote = QuoteService.GetContextualQuote(allNotes);
        StateHasChanged();
    }

    private async Task DeleteNote(Note note)
    {
        await NoteService.DeleteNoteAsync(note.Id);
        isEditing = false;
        await LoadData();
    }

    private void CancelEdit()
    {
        isEditing = false;
    }

    private void ToggleSelect()
    {
        showSelect = !showSelect;
    }

    private void SelectOption(string value)
    {
        sortBy = value;
        showSelect = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void CloseSelect()
    {
        showSelect = false;
        StateHasChanged();
    }

    private void SelectDateDesc()
    {
        sortBy = "date_desc";
        showSelect = false;
        StateHasChanged();
    }

    private void SelectDateAsc()
    {
        sortBy = "date_asc";
        showSelect = false;
        StateHasChanged();
    }
}