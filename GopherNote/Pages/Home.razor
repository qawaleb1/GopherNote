@page "/"
@using GopherNote.Models
@using GopherNote.Services
@inject NoteService NoteService
@inject QuoteService QuoteService

<PageTitle>GopherNote</PageTitle>

<TopQuote Quote="@CurrentQuote" />

<div class="layout">
    <aside class="sidebar">
        <h2 style="text-align: left">Notes</h2>
        <button class="btn-black" @onclick="CreateNewNote">Новая заметка</button>
        
        <div class="filters">
            <h3>Фильтры</h3>
            <input type="text" placeholder="Поиск по тегам..." @bind="tagFilter" @bind:event="oninput" />
            
            <select @bind="sortBy">
                <option value="date_desc">Сначала новые</option>
                <option value="date_asc">Сначала старые</option>
            </select>
        </div>
    </aside>

    <main class="content">
        @if (isEditing)
        {
            <EditNote Note="currentEditingNote" OnSave="SaveNote" OnCancel="CancelEdit" OnDelete="DeleteNote" />
        }
        else
        {
            <div class="notes-grid">
                @foreach (var note in FilteredAndSortedNotes)
                {
                    <NoteCard Note="note" OnPinToggled="SaveNote" OnEdit="StartEdit" />
                }
            </div>
        }
    </main>
</div>

@code {
    private List<Note> allNotes = new();
    private string CurrentQuote = "";
    private string tagFilter = "";
    private string sortBy = "date_desc";
    
    private bool isEditing = false;
    private Note currentEditingNote = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) // Выполняем только один раз при загрузке
        {
            try 
            {
                await LoadData();
                StateHasChanged(); // Принудительно обновляем интерфейс, так как данные пришли после рендера
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка загрузки: {ex.Message}");
            }
        }
    }

    private async Task LoadData()
    {
        allNotes = await NoteService.GetNotesAsync();
        CurrentQuote = QuoteService.GetContextualQuote(allNotes);
        StateHasChanged();
    }

    private IEnumerable<Note> FilteredAndSortedNotes
    {
        get
        {
            var filtered = allNotes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(tagFilter))
            {
                // Добавлена проверка n.Tags != null
                filtered = filtered.Where(n => n.Tags != null && 
                                               n.Tags.Any(t => t.Contains(tagFilter, StringComparison.OrdinalIgnoreCase)));
            }

            if (sortBy == "date_desc")
            {
                return filtered.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt);
            }
            else
            {
                return filtered.OrderByDescending(n => n.IsPinned).ThenBy(n => n.CreatedAt);
            }
        }
    }

    private void CreateNewNote()
    {
        currentEditingNote = new Note();
        isEditing = true;
    }

    private void StartEdit(Note note)
    {
        // Создаем копию объекта, чтобы редактор не ломал оригинал в списке
        currentEditingNote = new Note
        {
            Id = note.Id,
            Title = note.Title,
            Content = note.Content,
            IsPinned = note.IsPinned,
            Color = note.Color, // Копируем цвет
            Tags = note.Tags != null ? new List<string>(note.Tags) : new List<string>(),
            CreatedAt = note.CreatedAt
        };
        isEditing = true;
    }

    private async Task SaveNote(Note note)
    {
        // 1. Сначала отправляем заметку в сервис, чтобы она сохранилась
        await NoteService.SaveNoteAsync(note);
    
        // 2. Ищем эту заметку в нашем локальном списке на экране
        var index = allNotes.FindIndex(n => n.Id == note.Id);
        if (index != -1)
        {
            // 3. Жестко перезаписываем её актуальным объектом из редактора (вместе с цветом!)
            allNotes[index] = note;
        }
        else
        {
            // Если это была абсолютно новая заметка — добавляем её в список
            allNotes.Add(note);
        }

        isEditing = false;

        // 4. Пересчитываем цитату на основе обновленного списка
        CurrentQuote = QuoteService.GetContextualQuote(allNotes);
    
        // 5. ГЛАВНОЕ: Принудительно обновляем интерфейс БЕЗ перезапуска LoadData()
        StateHasChanged(); 
    }


    private async Task DeleteNote(Note note)
    {
        await NoteService.DeleteNoteAsync(note.Id);
        isEditing = false;
        await LoadData();
    }

    private void CancelEdit()
    {
        isEditing = false;
    }
}