@using GopherNote.Models

<div class="note-card @(Note.IsPinned ? "pinned-style" : "") @GetTemplateClass()">
    <div class="note-header">
        <span class="pin-icon" @onclick="TogglePin">@(Note.IsPinned ? "★" : "☆")</span>
        <h4>@Note.Title</h4>
    </div>

    <div class="note-preview">
        <MarkdownView Content="@(Note.Content.Length > 100 ? Note.Content.Substring(0,100) + "..." : Note.Content)"/>
    </div>

    @if (Note.Tags != null && Note.Tags.Any())
    {
        var maxTotalTags = 11;      // Максимум тегов ВСЕГО
        var maxVisibleTags = 5;     // Максимум видимых тегов
        var visibleTagsCount = Math.Min(maxVisibleTags, Note.Tags.Count);
        var visibleTags = Note.Tags.Take(visibleTagsCount).ToList();
        var remainingTags = Note.Tags.Skip(visibleTagsCount).ToList();

        // Если общее количество тегов превышает лимит, обрезаем скрытые
        if (remainingTags.Count + visibleTags.Count > maxTotalTags)
        {
            var maxRemaining = maxTotalTags - visibleTags.Count;
            remainingTags = remainingTags.Take(maxRemaining).ToList();
        }

        <div class="note-tags">
            @foreach (var tag in visibleTags)
            {
                <span class="tag" title="@tag">#@TruncateTag(tag)</span>
            }

            @if (remainingTags.Any())
            {
                <div class="tag-more">
                    <span class="tag">+ @remainingTags.Count</span>
                    <div class="tooltip-grid">
                        @foreach (var tag in remainingTags)
                        {
                            <span class="tooltip-tag" title="@tag">#@TruncateTag(tag)</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
    <div class="note-footer">
        <button class="btn-edit" @onclick="EditNote">Редактировать</button>
    </div>
</div>

@code {
    [Parameter] public Note Note { get; set; } = new();
    [Parameter] public EventCallback<Note> OnPinToggled { get; set; }
    [Parameter] public EventCallback<Note> OnEdit { get; set; }

    private async Task TogglePin()
    {
        Note.IsPinned = !Note.IsPinned;
        await OnPinToggled.InvokeAsync(Note);
    }

    private async Task EditNote()
    {
        await OnEdit.InvokeAsync(Note);
    }

    private string GetTemplateClass()
    {
        if (!string.IsNullOrEmpty(Note.TemplateClass))
            return Note.TemplateClass;

        if (!string.IsNullOrEmpty(Note.Color) && Note.Color.StartsWith("template-"))
            return $"note-{Note.Color}";

        return "note-template-1";
    }

    private string TruncateTag(string tag)
    {
        if (string.IsNullOrEmpty(tag))
            return "";

        if (tag.Length > 16)
            return tag.Substring(0, 13) + "...";

        return tag;
    }
}